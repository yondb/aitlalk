# DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=
# opcjonalnie: domyślnie deepseek-reasoner, przy błędzie automatycznie deepseek-chat
# DEEPSEEK_MODEL=deepseek-chat

# ElevenLabs — Flash v2.5 streaming TTS
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_A=
ELEVENLABS_VOICE_B=

# Pusher (server)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

# Pusher (browser — public)
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# Optional: public site URL for chained debate steps (falls back to VERCEL_URL / localhost)
NEXT_PUBLIC_APP_URL=

# Optional: protect internal /api/debate/[roomId]/step (defaults to dev-insecure)
DEBATE_INTERNAL_SECRET=

# Optional: pause between turns (ms) so moderators can intervene (default 3000)
DEBATE_BETWEEN_TURN_MS=3000

# Redis — jedna z opcji:
#
# A) REST (Upstash): dowolna para
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
#
# B) Jak w Quickstart na Vercelu — jeden string (hasło jest między default: a @):
# redis://default:HASLO@host:port
REDIS_URL=
