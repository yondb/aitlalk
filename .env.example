# DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=
# domyślnie deepseek-chat (szybka rozmowa). R1: DEEPSEEK_MODEL=deepseek-reasoner
# DEEPSEEK_MODEL=deepseek-reasoner

# TTS: przy ELEVENLABS_API_KEY domyślnie ElevenLabs (MP3). Bez klucza = brak mowy (tylko tekst).
# Jawny wymuszenie: TTS_PROVIDER=elevenlabs | none | browser
# Web Speech tylko jeśli TTS_PROVIDER=browser ORAZ build z NEXT_PUBLIC_TTS_PROVIDER=browser
# TTS_PROVIDER=browser
# NEXT_PUBLIC_TTS_PROVIDER=browser
#
# Start debaty czeka aż cały MP3 z ElevenLabs trafi do Pushera (dłuższy request — OK).
#
# ElevenLabs — głosy z Twojego planu (voice_id z panelu). Opcjonalnie:
# ELEVENLABS_MODEL_ID=eleven_flash_v2_5
# ELEVENLABS_SPEED=1.1
# ELEVENLABS_STABILITY=0.5
# ELEVENLABS_SIMILARITY_BOOST=0.75
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_A=
ELEVENLABS_VOICE_B=

# Pusher (server)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

# Pusher (browser — public)
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# Optional: public site URL for chained debate steps (falls back to VERCEL_URL / localhost)
NEXT_PUBLIC_APP_URL=

# Optional: protect internal /api/debate/[roomId]/step (defaults to dev-insecure)
DEBATE_INTERNAL_SECRET=

# Pauza między turami (ms), domyślnie 1500
DEBATE_BETWEEN_TURN_MS=1500
# Tylko tekst, bez mowy (nadpisuje TTS_PROVIDER)
# SKIP_TTS=1

# Redis — jedna z opcji:
#
# A) REST (Upstash): dowolna para
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
#
# B) Jak w Quickstart na Vercelu — jeden string (hasło jest między default: a @):
# redis://default:HASLO@host:port
REDIS_URL=
